{
  "manifest_version": 3,
  "name": "EtchSpy",
  "version": "1.2.0",
  "description": "Etsy product research tool — overlay estimated sales data on search results and export to CSV.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["*://*.etsy.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.etsy.com/search*"],
      "js": ["storage.js", "license.js", "csv_export.js", "content_etsy_search.js"],
      "css": ["styles/overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.etsy.com/listing/*"],
      "js": ["storage.js", "license.js", "csv_export.js", "content_etsy_listing.js"],
      "css": ["styles/overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.etsy.com/shop/*"],
      "js": ["storage.js", "license.js", "csv_export.js", "content_etsy_shop.js"],
      "css": ["styles/overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
